rules_version = '2';

// Reglas de Firebase Storage.
// - Lectura pública: las imágenes y descargas se muestran en la vitrina pública.
// - Escritura: solo un usuario autenticado, en SU propia carpeta. Se permiten
//   imágenes (hasta 8 MB) y APKs de Android (hasta 100 MB, para espacios de apps).
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && (
                        (request.resource.size < 8 * 1024 * 1024
                          && request.resource.contentType.matches('image/.*'))
                        || (request.resource.size < 100 * 1024 * 1024
                          && request.resource.contentType == 'application/vnd.android.package-archive')
                      );
    }
  }
}
